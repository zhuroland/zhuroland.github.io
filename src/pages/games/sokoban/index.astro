---
import Layout from "../../../layouts/SokobanLayout.astro";
import Button from "../../../components/button.astro";
---

<Layout
  title="Sokoban Game"
  description="Play Sokoban, a classic puzzle game where you push boxes to their targets."
>
  <div class="page-shell">
    <header class="navigation">
      <div class="title-block">
        <h1>Sokoban Game</h1>
        <p>Push every box onto a target. Swipe on the board or use arrow keys to move.</p>
      </div>
      <div class="navigation-actions">
        <Button href="/games" class="compact-button">Go back</Button>
        <Button href="/games/sokoban/maker" class="compact-button">Level Maker</Button>
      </div>
    </header>

    <main class="game-container">
      <div class="controls" aria-label="Level controls">
        <button type="button" data-canvas-prev>← Previous Level</button>
        <button type="button" data-canvas-restart>Restart Level</button>
        <button type="button" data-canvas-next>Next Level →</button>
      </div>

      <div class="canvas-shell">
        <canvas data-canvas-game width="800" height="600"></canvas>
      </div>
    </main>
  </div>
</Layout>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(128, 167, 255, 0.18), transparent 35%),
      linear-gradient(180deg, #f7f9fc 0%, #eef3ff 100%);
    color: #1f2937;
  }

  * {
    box-sizing: border-box;
  }

  .page-shell {
    min-height: 100vh;
    padding: clamp(1rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .navigation {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .title-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .title-block h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .title-block p {
    margin: 0;
    max-width: 52ch;
    color: #516074;
  }

  .navigation-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    width: min(100%, 320px);
  }

  .navigation-actions :global(div) {
    padding: 0;
    box-shadow: none;
    border-radius: 999px;
    background: none;
  }

  .navigation-actions :global(a),
  .navigation-actions :global(button) {
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 1;
    background-color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
  }

  .game-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    width: 100%;
  }

  .controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    width: 100%;
    max-width: 40rem;
  }

  button {
    --btn-lightness: 40%;
    padding: 0.5rem 0.8rem;
    border: none;
    border-radius: 0.85rem;
    cursor: pointer;
    background: oklch(var(--btn-lightness) 0.05 260);
    color: oklch(90% 0 0);
    font-weight: 600;
    font-size: 0.92rem;
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      background 0.15s ease;
    touch-action: manipulation;
  }

  button:hover {
    --btn-lightness: 50%;
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.1);
  }

  button[data-canvas-restart] {
    background: oklch(var(--btn-lightness) 0.1 30);
  }

  .canvas-shell {
    width: 100%;
    display: flex;
    justify-content: center;
    padding-bottom: 0.25rem;
  }

  canvas {
    display: block;
    width: 100%;
    max-width: none;
    border-radius: 1.25rem;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.16);
    border: 1px solid rgba(15, 23, 42, 0.1);
    cursor: grab;
  }

  button:focus-visible {
    outline: 2px solid oklch(68% 0.12 255);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .page-shell {
      padding: 0.75rem;
    }

    .navigation-actions {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .controls {
      width: 100%;
    }

    .controls button {
      width: 100%;
      min-width: 0;
      padding-inline: 0.4rem;
      font-size: 0.8rem;
    }

    .navigation-actions :global(a),
    .navigation-actions :global(button) {
      width: 100%;
    }
  }

  @media (max-width: 360px) {
    .page-shell {
      padding: 0.5rem;
    }

    .title-block h1 {
      font-size: 1.8rem;
    }

    .title-block p {
      font-size: 0.92rem;
    }

    .controls {
      gap: 0.35rem;
    }

    .navigation-actions :global(a),
    .navigation-actions :global(button) {
      padding: 0.45rem 0.6rem;
      font-size: 0.82rem;
    }
  }
</style>

<script>
  import { getCanvasContext } from "../../../utils/canvas";
  import { levels } from "./levels";

  interface Position {
    x: number;
    y: number;
  }

  type CellType = "wall" | "floor" | "target";

  const { canvas, ctx } = getCanvasContext();
  const MAX_TILE_SIZE = 50;
  const MIN_TILE_SIZE = 10;
  const CANVAS_PADDING = 24;

  let playerPos: Position = { x: 0, y: 0 };
  let gameMap: CellType[][] = [];
  let boxes: Position[] = [];
  let targets: Position[] = [];
  let currentLevel = 0;
  let moves = 0;
  let gameComplete = false;
  let isGameReady = false;
  let tileSize = MAX_TILE_SIZE;
  let swipeStartX = 0;
  let swipeStartY = 0;
  let activePointerId: number | null = null;
  const SWIPE_THRESHOLD = 24;

  const images = {
    player: new Image(),
    wall: new Image(),
    box: new Image(),
    target: new Image(),
    ground: new Image(),
  };

  function init(): void {
    loadImages();
    setupControls();
  }

  function loadImages(): void {
    let loadedImages = 0;
    const totalImages = Object.keys(images).length;

    const loadHandler = () => {
      loadedImages++;
      if (loadedImages === totalImages) {
        // All images loaded, start the game
        isGameReady = true;
        initLevel(currentLevel);
        // Start the game loop
        requestAnimationFrame(gameLoop);
      }
    };

    // Set up image sources and load handlers
    images.player.onload = loadHandler;
    images.wall.onload = loadHandler;
    images.box.onload = loadHandler;
    images.target.onload = loadHandler;
    images.ground.onload = loadHandler;

    images.player.src = "/assets/sokoban/cat.png";
    images.wall.src = "/assets/sokoban/wall.png";
    images.box.src = "/assets/sokoban/box.png";
    images.target.src = "/assets/sokoban/target.png";
    images.ground.src = "/assets/sokoban/ground.png";
  }

  function initLevel(levelIdx: number): void {
    if (levelIdx >= levels.length) {
      levelIdx = 0;
    }

    currentLevel = levelIdx;
    moves = 0;
    gameComplete = false;

    playerPos = { x: 0, y: 0 };
    gameMap = [];
    boxes = [];
    targets = [];

    parseLevel(levels[levelIdx].map);
    resizeCanvas();
  }

  function resizeCanvas(): void {
    if (gameMap.length === 0) {
      return;
    }

    const maxWidth = Math.max(...gameMap.map((row) => row.length));
    const maxHeight = gameMap.length;
    const canvasShell = document.querySelector(".canvas-shell") as HTMLElement | null;
    const navigation = document.querySelector(".navigation") as HTMLElement | null;
    const controls = document.querySelector(".controls") as HTMLElement | null;
    const shellWidth = canvasShell?.clientWidth ?? window.innerWidth - CANVAS_PADDING;
    const navHeight = navigation?.getBoundingClientRect().height ?? 0;
    const controlsHeight = controls?.getBoundingClientRect().height ?? 0;
    const staticSpacing = window.innerWidth <= 480 ? 72 : 96;

    const availableWidth = Math.max(shellWidth, 240);
    const availableHeight = Math.max(
      window.innerHeight - navHeight - controlsHeight - staticSpacing,
      180
    );

    tileSize = Math.max(
      MIN_TILE_SIZE,
      Math.min(
        MAX_TILE_SIZE,
        Math.floor(availableWidth / maxWidth),
        Math.floor(availableHeight / maxHeight)
      )
    );

    const canvasWidth = availableWidth;
    const canvasHeight = maxHeight * tileSize + 40;

    canvas.width = canvasWidth;
    canvas.height = canvasHeight;
    canvas.style.width = "100%";
    canvas.style.height = "auto";
  }

  function parseLevel(levelMap: string[]): void {
    for (let y = 0; y < levelMap.length; y++) {
      const row = levelMap[y];
      gameMap[y] = [];

      for (let x = 0; x < row.length; x++) {
        const cell = row[x];

        switch (cell) {
          case "W":
            gameMap[y][x] = "wall";
            break;
          case "B":
            gameMap[y][x] = "floor";
            boxes.push({ x, y });
            break;
          case "T":
            gameMap[y][x] = "target";
            targets.push({ x, y });
            break;
          case "G":
            gameMap[y][x] = "target";
            boxes.push({ x, y });
            targets.push({ x, y });
            break;
          case "P":
            gameMap[y][x] = "floor";
            playerPos = { x, y };
            break;
          case "+": // player on target
            gameMap[y][x] = "target";
            targets.push({ x, y });
            playerPos = { x, y };
            break;
          default:
            gameMap[y][x] = "floor";
        }
      }
    }
  }

  function setupControls(): void {
    document.addEventListener("keydown", handleKeydown);
    window.addEventListener("resize", resizeCanvas);

    const restartButton = document.querySelector("[data-canvas-restart]");
    const nextLevelButton = document.querySelector("[data-canvas-next]");
    const prevLevelButton = document.querySelector("[data-canvas-prev]");

    if (restartButton) {
      restartButton.addEventListener("click", (e) => {
        initLevel(currentLevel);
        (e.currentTarget as HTMLButtonElement).blur();
      });
    }

    if (nextLevelButton) {
      nextLevelButton.addEventListener("click", (e) => {
        if (currentLevel < levels.length - 1) {
          initLevel(currentLevel + 1);
        } else {
          initLevel(0);
        }
        (e.currentTarget as HTMLButtonElement).blur();
      });
    }

    if (prevLevelButton) {
      prevLevelButton.addEventListener("click", (e) => {
        if (currentLevel > 0) {
          initLevel(currentLevel - 1);
        } else {
          initLevel(levels.length - 1);
        }
        (e.currentTarget as HTMLButtonElement).blur();
      });
    }

    canvas.addEventListener("pointerdown", handlePointerDown);
    canvas.addEventListener("pointerup", handlePointerUp);
    canvas.addEventListener("pointercancel", handlePointerCancel);
    canvas.addEventListener("pointerleave", handlePointerCancel);
  }

  function handlePointerDown(event: PointerEvent): void {
    if (event.pointerType === "mouse" && event.button !== 0) {
      return;
    }

    activePointerId = event.pointerId;
    swipeStartX = event.clientX;
    swipeStartY = event.clientY;
    canvas.setPointerCapture(event.pointerId);
  }

  function handlePointerUp(event: PointerEvent): void {
    if (activePointerId !== event.pointerId) {
      return;
    }

    const deltaX = event.clientX - swipeStartX;
    const deltaY = event.clientY - swipeStartY;
    activePointerId = null;

    if (gameComplete) {
      if (currentLevel < levels.length - 1) {
        nextLevel();
      }
      return;
    }

    if (Math.abs(deltaX) < SWIPE_THRESHOLD && Math.abs(deltaY) < SWIPE_THRESHOLD) {
      return;
    }

    if (Math.abs(deltaX) > Math.abs(deltaY)) {
      movePlayer(deltaX > 0 ? 1 : -1, 0);
    } else {
      movePlayer(0, deltaY > 0 ? 1 : -1);
    }
  }

  function handlePointerCancel(event: PointerEvent): void {
    if (activePointerId === event.pointerId) {
      activePointerId = null;
    }
  }

  function handleKeydown(event: KeyboardEvent): void {
    if (!isGameReady || gameComplete) {
      if (gameComplete && event.key === " ") {
        nextLevel();
        return;
      }

      if (gameComplete && (event.key === "r" || event.key === "R")) {
        initLevel(0);
        return;
      }

      return;
    }

    let dx = 0;
    let dy = 0;

    switch (event.key) {
      case "ArrowUp":
        dy = -1;
        break;
      case "ArrowDown":
        dy = 1;
        break;
      case "ArrowLeft":
        dx = -1;
        break;
      case "ArrowRight":
        dx = 1;
        break;
      case "r":
      case "R":
        initLevel(currentLevel);
        return;
      case "Escape":
        initLevel(currentLevel);
        return;
      default:
        return;
    }

    if (dx !== 0 || dy !== 0) {
      movePlayer(dx, dy);
      event.preventDefault();
    }
  }

  function nextLevel(): void {
    if (currentLevel < levels.length - 1) {
      initLevel(currentLevel + 1);
    } else {
      gameComplete = true;
    }
  }

  function movePlayer(dx: number, dy: number): void {
    if (!isGameReady || gameComplete) {
      return;
    }

    const newX = playerPos.x + dx;
    const newY = playerPos.y + dy;

    if (isWall(newX, newY)) {
      return;
    }

    const boxIndex = getBoxAt(newX, newY);
    if (boxIndex !== -1) {
      const newBoxX = newX + dx;
      const newBoxY = newY + dy;

      if (isWall(newBoxX, newBoxY) || getBoxAt(newBoxX, newBoxY) !== -1) {
        return;
      }

      boxes[boxIndex].x = newBoxX;
      boxes[boxIndex].y = newBoxY;
    }

    playerPos.x = newX;
    playerPos.y = newY;
    moves++;
  }

  function isWall(x: number, y: number): boolean {
    if (y < 0 || y >= gameMap.length || x < 0 || x >= gameMap[y].length) {
      return true;
    }
    return gameMap[y][x] === "wall";
  }

  function getBoxAt(x: number, y: number): number {
    return boxes.findIndex((box) => box.x === x && box.y === y);
  }

  function isTarget(x: number, y: number): boolean {
    return targets.some((target) => target.x === x && target.y === y);
  }

  function checkWin(): boolean {
    const allBoxesOnTargets = targets.every((target) =>
      boxes.some((box) => box.x === target.x && box.y === target.y)
    );

    if (allBoxesOnTargets && !gameComplete) {
      gameComplete = true;

      if (currentLevel === levels.length - 1) {
        console.log("Game complete!");
      } else {
        console.log(`Level ${currentLevel + 1} complete!`);
      }
    }

    return allBoxesOnTargets;
  }

  function draw(): void {
    if (!isGameReady || !ctx) return;

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const boardWidth = Math.max(...gameMap.map((row) => row.length)) * tileSize;
    const offsetX = Math.max((canvas.width - boardWidth) / 2, 0);
    const offsetY = 0;

    for (let y = 0; y < gameMap.length; y++) {
      for (let x = 0; x < gameMap[y].length; x++) {
        const cell = gameMap[y][x];
        const posX = offsetX + x * tileSize;
        const posY = offsetY + y * tileSize;

        if (cell === "floor") {
          ctx.drawImage(images.ground, posX, posY, tileSize, tileSize);
        } else if (cell === "wall") {
          ctx.drawImage(images.wall, posX, posY, tileSize, tileSize);
        } else if (cell === "target") {
          ctx.drawImage(images.target, posX, posY, tileSize, tileSize);
        }
      }
    }

    boxes.forEach((box) => {
      const posX = offsetX + box.x * tileSize;
      const posY = offsetY + box.y * tileSize;
      const onTarget = isTarget(box.x, box.y);

      ctx.drawImage(images.box, posX, posY, tileSize, tileSize);

      if (onTarget) {
        ctx.fillStyle = "rgba(0, 255, 0, 0.3)";
        ctx.fillRect(posX, posY, tileSize, tileSize);
      }
    });

    ctx.drawImage(
      images.player,
      offsetX + playerPos.x * tileSize,
      offsetY + playerPos.y * tileSize,
      tileSize,
      tileSize
    );

    ctx.fillStyle = "black";
    ctx.font = "16px Arial";

    const levelLabel = `Level: ${currentLevel + 1}/${levels.length}`;
    const movesLabel = `Moves: ${moves}`;
    const compactLabel = `L ${currentLevel + 1}/${levels.length} • M ${moves}`;
    const labelY = canvas.height - 10;
    const horizontalPadding = 10;
    const minGap = 16;

    const levelWidth = ctx.measureText(levelLabel).width;
    const movesWidth = ctx.measureText(movesLabel).width;
    const labelsFit = levelWidth + movesWidth + minGap <= canvas.width - horizontalPadding * 2;

    if (labelsFit) {
      ctx.textAlign = "left";
      ctx.fillText(levelLabel, horizontalPadding, labelY);

      ctx.textAlign = "right";
      ctx.fillText(movesLabel, canvas.width - horizontalPadding, labelY);
    } else {
      ctx.textAlign = "center";
      ctx.fillText(compactLabel, canvas.width / 2, labelY);
    }

    ctx.textAlign = "left";

    if (gameComplete) {
      ctx.fillStyle = "rgba(0, 0, 0, 0.7)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "white";
      ctx.font = "32px Arial";

      if (currentLevel < levels.length - 1) {
        ctx.fillText(
          "Level Complete!",
          canvas.width / 2 - 120,
          canvas.height / 2 - 20
        );
        ctx.font = "20px Arial";
        ctx.fillText(
          "Tap screen or press Space",
          canvas.width / 2 - 120,
          canvas.height / 2 + 20
        );
      } else {
        ctx.fillText(
          "Game Complete!",
          canvas.width / 2 - 120,
          canvas.height / 2 - 20
        );
        ctx.font = "20px Arial";
        ctx.fillText(
          "Press R to restart game",
          canvas.width / 2 - 100,
          canvas.height / 2 + 20
        );
      }
    }
  }

  function update(): void {
    if (gameComplete) return;

    checkWin();
  }

  function gameLoop(): void {
    update();

    draw();

    requestAnimationFrame(gameLoop);
  }

  window.addEventListener("load", init);
</script>
